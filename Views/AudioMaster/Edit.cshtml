@model AudioMaster
<div class="container">
	<div class="text-center text-uppercase ">
		<h2>Audio Master Edit</h2>
	</div>
	<hr />
	<div class="row align-content-center justify-content-center  g-5 d-flex ">
		<div class=" col-md-6 border-1 border">
			<form method="post" enctype="multipart/form-data">
				<input  asp-for="@Model.AudioId" hidden/>
				<div class="mb-3">
					<label asp-for="@Model.AudioName" class="form-label fw-bold"></label>
					<input asp-for="@Model.AudioName" class="form-control" />
					<span asp-validation-for="@Model.AudioName" class="text-danger"></span>
				</div>
				<div class="mb-3">
					<label asp-for="@Model.AuthorName" class="form-label fw-bold"></label>
					<input asp-for="@Model.AuthorName" class="form-control" />
				</div>
				<div class="mb-3">
					<label asp-for="@Model.MovieName" class="form-label fw-bold"></label>
					<input asp-for="@Model.MovieName" class="form-control" />
				</div>
				<div class="mb-3">
					<label asp-for="@Model.Rate" class="form-label fw-bold"></label>
					<input asp-for="@Model.Rate" class="form-control" />
					<span asp-validation-for="@Model.Rate" class="text-danger"></span>
				</div>
				<div class="mb-3">
					<label asp-for="@Model.CoverImage" class="form-label fw-bold"></label>
					<input asp-for="@Model.CoverImage" type="file" name="Files" id="uploadBox" class="form-control" />
				</div>
				<div class="mb-3">
					<button type="submit" class="btn btn-warning"> Submit</button>
					<a asp-controller="AudioMaster" asp-action="Index" class="btn btn-danger"> Back</a>
				</div>
			</form>
		</div>

		<div class="col-md-4 ">
			<img src="@Model.CoverImage" class="img-fluid" />
		</div>
		
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial"></partial>

}





