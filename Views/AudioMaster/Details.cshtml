@model AudioMaster
<div class="card">
	<div class="card-header text-center text-uppercase">Audio Details</div>
	<div class="card-body ">

		<div class="row">
			<div class="col-md-8">
				<div class="row">
					<div class="col-md-4">
						<p class="card-text text-uppercase"><strong>Audio ID</strong> </p>
					</div>
					<div class="col-md-4">
						<p class="card-text"> : @Model.AudioId</p>
					</div>
				</div>
				<div class="row">
					<div class="col-md-4">
						<p class="card-text text-uppercase"><strong>Audio Name</strong> </p>
					</div>
					<div class="col-md-4">
						<p class="card-text"> : @Model.AudioName</p>
					</div>
				</div>
				<div class="row">
					<div class="col-md-4">
						<p class="card-text text-uppercase"><strong>Author Name</strong> </p>
					</div>
					<div class="col-md-4">
						<p class="card-text"> : @Model.AuthorName</p>
					</div>
				</div>
				<div class="row">
					<div class="col-md-4">
						<p class="card-text text-uppercase"><strong>Movie Name</strong> </p>
					</div>
					<div class="col-md-4">
						<p class="card-text"> : @Model.MovieName</p>
					</div>
				</div>
				<div class="row">
					<div class="col-md-4">
						<p class="card-text text-uppercase"><strong>Rate</strong> </p>
					</div>
					<div class="col-md-4">
						<p class="card-text"> : @Model.Rate.ToString("#0.00") </p>
					</div>
				</div>
			</div>
			<div class="col-md-4">
				@* <div  style="width:400px;height:400px"> *@


				<img src="@Model.CoverImage" class="img-fluid border border-3" />
				@* </div> *@
			</div>
		</div>
		<div class="row">
			<div class="col-md-12 text-center">
				<a asp-controller="AudioMaster" asp-action="Index" class="btn btn-danger"><i class="bi bi-arrow-left-circle"></i> Back</a>
			</div>
		</div>
	</div>

</div>