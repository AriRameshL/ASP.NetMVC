@model List<AudioMaster>
<div class=" container">
	<div class="row mb-4">
		<div class="text-uppercase col-md-6">
			<h2>Audio Master</h2>
		</div>
		<div class="col-md-3 text-end">
			<a asp-controller="AudioMaster" asp-action="Create" class="btn btn-primary">
				<i class="bi bi-person-add"></i> Create
			</a>
		</div>
		<div class="col-md-3 text-start">
			<a asp-controller="AudioMaster" asp-action="CardView" class="btn btn-warning">
				<i class="bi bi-back"></i> View
			</a>
		</div>
	</div>
	<hr />
	@if (Model.Count > 0)
	{
		<table id="table" class="table table-bordered border">
			<thead>
				<tr>
					<td class="text-center fw-bold"> Audio Id</td>
					<td class="text-center fw-bold"> Audio Name</td>
					<td class="text-center fw-bold"> Author Name</td>
					<td class="text-center fw-bold"> Movie Name</td>
					<td class="text-center fw-bold"> Rate</td>
					<td class="text-center fw-bold"> Action</td>
				</tr>
			</thead>
			<tbody>
				@foreach (var item in Model)
				{
					<tr>
						<td class="text-end">@item.AudioId </td>
						<td>@item.AudioName</td>
						<td>@item.AuthorName</td>
						<td>@item.MovieName </td>
						<td class="text-end">@item.Rate </td>
						<td class="d-flex align-items-center justify-content-center">
							<div class="w-50 btn-group" role="group">
								<a asp-controller="AudioMaster" asp-action="Details" asp-route-_AudioId="@item.AudioId"
								   Class="btn btn-info" data-toggle="tooltip" data-placement="Top" title="Details">
									<i class="bi bi-arrow-right-circle"></i>
								</a>
								<a asp-controller="AudioMaster" asp-action="Edit" asp-route-_AudioId="@item.AudioId"
								   Class="btn btn-warning" data-toggle="tooltip" data-placement="Top" title="Edit">
									<i class="bi bi-pencil-square"></i>
								</a>
								<a asp-controller="AudioMaster" asp-action="Delete" asp-route-_AudioId="@item.AudioId"
								   Class="btn btn-danger" data-toggle="tooltip" data-placement="Top" title="Delete">
									<i class="bi bi-trash3-fill"></i>
								</a>
							</div>
						</td>
					</tr>
				}
			</tbody>

		</table>
	}
	else
	{
		<div class="col-md-12 text-center text-uppercase text-warning pt-2 "> No Audio Data Found</div>
	}

</div>
@section Scripts {
	<script>
		$('.table').DataTable();
	</script>
}





