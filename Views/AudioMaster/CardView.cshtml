@model List<AudioMaster>
<div class="container">
	<div class="row">
		<h2 class="col-md-8 text-uppercase "> Audio Master</h2>
		<div class="col-md-4 text-end">
			<a asp-controller="AudioMaster" asp-action="Index" class="btn btn-danger">
				<i class="bi bi-arrow-left-circle"></i> Back
			</a>
		</div>
	</div>
	<div class="d-flex" style="flex-wrap:wrap;">
		@foreach (AudioMaster item in Model)
		{
			<div class="card align-content-center justify-content-center  g-5 col-md-5" style="margin:20px">
				<div class="card-header text-center">
					@item.AudioName
				</div>
				<img src="@item.CoverImage" class="col-md-4 d-flex border border-3" />
				<div class="row">
					<div class="col-md-4 fw-bold"> Audio Id</div>
					<div class="col-md-8 ">: @item.AudioId</div>
				</div>
				<div class="row">
					<div class="col-md-4 fw-bold"> Author Name</div>
					<div class="col-md-8 ">: @item.AuthorName</div>
				</div>
				<div class="row">
					<div class="col-md-4 fw-bold"> Category Name</div>
					<div class="col-md-8 ">: @item.MovieName</div>
				</div>
				<div class="row">
					<div class="col-md-4 fw-bold"> Rate</div>
					<div class="col-md-8 ">: @item.Rate</div>
				</div>
			</div>
			<br />
		}
	</div>

</div> 