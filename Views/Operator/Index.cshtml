@model Operator
<div class="container col-md-6 border border-3">
	<div class="row">
		<div class="col-md-6">
			<h4><i class="bi bi-person-vcard"></i>  Operater Creation</h4>
		</div>
		<div class="col-md-6 text-end" style="padding-right:15px">
			<a asp-Controller="Operator" asp-action="DetailView" class="btn btn-warning"><i class="bi bi-card-list"></i> View </a>
		</div>
	</div>
	<hr />
	<div class="row">
		<form method="post">
			<div class="row" style="margin-bottom:5px">
				<div class="col-md-4">
					<label class="form-label"> Operator Name</label>
				</div>
				<div class="col-md-8">
					<input asp-for="@Model.OperName" type="text" id="OperName" class="form-control" />
					<span asp-validation-for="@Model.OperName" class="text-danger"></span>
				</div>
			</div>
			<div class="row" style="margin-bottom:5px">
				<div class="col-md-4">
					<label class="form-label"> Mobile No</label>
				</div>
				<div class="col-md-8">
					<input asp-for="@Model.MobileNo" type="text" id="MobileNo" class="form-control" />
					<span asp-validation-for="@Model.MobileNo" class="text-danger"></span>
				</div>
			</div>
			<div class="row" style="margin-bottom:5px">
				<div class="col-md-4">
					<label class="form-label"> Email</label>
				</div>
				<div class="col-md-8">
					<input asp-for="@Model.Email" type="text" id="Email" class="form-control" />
					<span asp-validation-for="@Model.Email" class="text-danger"></span>
				</div>
			</div>
			<div class="row" style="margin-bottom:5px">
				<div class="col-md-4">
					<label class="form-label"> Date Of Birth </label>
				</div>
				<div class="col-md-8">
					<input asp-for="@Model.DOB" type="date" id="DOB" class="form-control" />
					<span asp-validation-for="@Model.DOB" class="text-danger"></span>
				</div>
			</div>
			<div class="row" style="margin-bottom:5px">
				<div class="col-md-4">
					<label class="form-label"> Password</label>
				</div>
				<div class="col-md-8">
					<input asp-for="@Model.Password" type="text" id="Password" class="form-control" />
					<span asp-validation-for="@Model.Password" class="text-danger"></span>
				</div>
			</div>
			<div class="row" style="margin-bottom:5px">
				<div class="col-md-4">
					<label class="form-label"> Gender</label>
				</div>
				<div class="col-md-8">
					@Html.DropDownListFor(m => m.Gender, ViewBag.Gender as SelectList, new { @class = "form-select", @id = "Gender" })
					@* <input asp-for="@Model.Gender" type="text" id="Gender" class="form-control" hidden/> 
					<span asp-validation-for="@Model.Gender" class="text-danger"></span> *@
				</div>
			</div>
			<div class="row" style="margin-bottom:5px">
				<div class="col-md-4">
					<label class="form-label"> Address</label>
				</div>
				<div class="col-md-8">
					<input asp-for="@Model.Address" type="text" id="Address" class="form-control" />
					<span asp-validation-for="@Model.Address" class="text-danger"></span>
				</div>
			</div>
			<div class="row" style="margin-bottom:5px">
				<div class="col-md-4">
					<label class="form-label"> City</label>
				</div>
				<div class="col-md-8">
					<input asp-for="@Model.City" type="text" id="City" class="form-control" />
					<span asp-validation-for="@Model.City" class="text-danger"></span>
				</div>
			</div>
			<div class="row" style="margin-bottom:15px">
				<div class="col-md-4">
					<label class="form-label"> Active</label>
				</div>
				<div class="col-md-8">
					@Html.DropDownListFor(m => m.Active, ViewBag.YesNo as SelectList, new { @class = "form-select", @id = "Active" })
					@* <input asp-for="@Model.Active" type="text" id="Active" class="form-control" />
					<span asp-validation-for="@Model.Active" class="text-danger"></span> *@
				</div>
			</div>
			<div class="row" style="margin-bottom:5px">
				<div class="col-md-4"> </div>
				<div class="col-md-4 text-center">
					<button class="col-md-8 btn btn-primary" type="submit"><i class="bi bi-person-add"></i> Save </button>
				</div>
				<div class="col-md-4 text-start">
					<a asp-controller="Operator" asp-action="Index" class="col-md-8 btn btn-danger"><i class="bi bi-arrow-clockwise"></i> Clear </a>
				</div>
			</div>
		</form>
	</div>
</div>


