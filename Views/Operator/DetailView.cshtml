@model List<Operator>
<div class="container">
	<div class="row">
		<h4> Operator's Details </h4>
		<hr />
	</div>
	@if (Model.Count > 0)
	{
		<table class="table-bordered border">
			<thead>
				<tr>
					<td class="text-center fw-bold"> Id </td>
					<td class="text-center fw-bold"> Name </td>
					<td class="text-center fw-bold"> DOB </td>
					<td class="text-center fw-bold"> Gender</td>
					<td class="text-center fw-bold"> Mobile No</td>
					<td class="text-center fw-bold"> Email</td>
					<td class="text-center fw-bold"> Address</td>
					<td class="text-center fw-bold"> City</td>
					<td class="text-center fw-bold"> Active</td>
				</tr>
			</thead>
			<tbody>
				@foreach (Operator item in Model)
				{
					<tr>
						<td class="text-center">@item.OperCode</td>
						<td class="text-start">@item.OperName</td>
						<td class="text-center">@item.DOB.ToString("dd-MMM-yyyy")</td>
						<td> @(item.Gender.ToString()=="M" ? "Male" : (item.Gender.ToString()=="F" ? "Female" : "Other"))</td>
						<td>@item.MobileNo</td>
						<td>@item.Email</td>
						<td>@item.Address</td>
						<td>@item.City</td>
						<td>@(item.Active.ToString()=="Y"? "Yes":"No")</td>
					</tr>
				}
			</tbody>
		</table>
	}
	else
	{
		<div class="row">
			<h4> No Operator Data Found </h4>
		</div>
	}
</div>