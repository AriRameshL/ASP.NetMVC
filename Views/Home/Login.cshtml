@{
	Layout = null;
}

<!DOCTYPE html>
<html>
<head>
	<title>Login</title>

	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<style>

		body {
			background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
			height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
			font-family: "Segoe UI", sans-serif;
		}

		.login-box {
			width: 400px;
			background: #fff;
			border-radius: 18px;
			padding: 35px;
			box-shadow: 0 15px 35px rgba(0,0,0,.2);
			transition: .3s;
		}

			.login-box:hover {
				transform: translateY(-3px);
				box-shadow: 0 20px 45px rgba(0,0,0,.25);
			}

		.profile-icon {
			width: 110px;
			height: 110px;
			border-radius: 50%;
			margin: auto;
			background: #0d6efd;
			color: white;
			font-size: 55px;
			display: flex;
			justify-content: center;
			align-items: center;
			margin-bottom: 25px;
			box-shadow: 0 8px 20px rgba(13,110,253,.4);
		}

		.input-group-text {
			background: white;
			color: #0d6efd;
			border: 1px solid #ced4da;
			border-right: none;
		}

		.form-control {
			border-left: none;
		}

			.form-control:focus {
				box-shadow: none;
				border-color: #0d6efd;
			}

		.eye-btn {
			background: white;
			border-left: none;
			border-color: #ced4da;
		}

		.btn-primary {
			border-radius: 30px;
			font-weight: 600;
			padding: 10px;
			transition: .3s;
		}

			.btn-primary:hover {
				transform: scale(1.03);
			}

		.text-danger {
			font-size: 14px;
		}

		.login-title {
			text-align: center;
			color: #0d6efd;
			font-weight: bold;
			margin-bottom: 25px;
		}

		.footer-text {
			text-align: center;
			color: gray;
			font-size: 13px;
			margin-top: 20px;
		}
	</style>

</head>

<body>

	<div class="container h-100">
		<div class="row h-100 justify-content-center align-items-center">
			<div class="login-box">
				<div class="login-title">
					<h2>RLD Audio Seller</h2>
					<p class="text-muted mb-0">Sign in to continue</p>
				</div>

				<div class="profile-icon">
					<i class="bi bi-person-fill"></i>
				</div>

				<form name="Frm_Login">
					<div class="input-group">
						<span class="input-group-text">
							<i class="bi bi-person-fill"></i>
						</span>

						<input type="text"
							   class="form-control"
							   Id="username"
							   name="UserName"
							   placeholder="Enter Username" />
					</div>
					<span class="text-danger text-center" id="UserError"></span>
					<br />

					<div class="input-group">
						<span class="input-group-text">
							<i class="bi bi-lock-fill"></i>
						</span>
						<input type="password"
							   class="form-control"
							   id="password"
							   name="Password"
							   placeholder="Enter Password" />

						<button type="button"
								class="btn eye-btn"
								onclick="showPassword()">
							<i id="eye" class="bi bi-eye-slash"></i>
						</button>
					</div>
					<span class="text-danger text-center" id="PassError"></span>
					<br />

					<button type="button" class="btn btn-primary w-100 mt-3" onclick="BtnLogin_Click()">
						<i class="bi bi-box-arrow-in-right"></i>
						 Login
					</button>
					<span class="text-danger text-center" id="LoginError"></span>
				</form>

			</div>
			<div class="footer-text">
				© 2026 RLD Audio Seller
			</div>
		</div>

	</div>

	<script>

		function showPassword() {

			var txt = document.getElementById("password");
			var eye = document.getElementById("eye");

			if (txt.type == "password") {
				txt.type = "text";
				eye.className = "bi bi-eye";
			}
			else {
				txt.type = "password";
				eye.className = "bi bi-eye-slash";
			}

		}
		function BtnLogin_Click(){
			var User=$("#username").val();
			var Pass=$("#password").val();
			console.log(User);
			console.log(Pass);
			$("#UserError").text("");
			$("#PassError").text("");
			$("#LoginError").text("");

			if (User == "") {
				$("#UserError").text("Please enter User Name.");
				return;
			}
			if (Pass == "") {
				$("#PassError").text("Please enter Password.");
				return;
			}

			$.ajax({
				url:"/Home/CheckLogin",
				type:'POST',
				data:{UserName:User,Pass:Pass},
				success:function(data){
					if(data==0){
						$("#LoginError").text("User Name or Password is Invalid");
					}
					else{
						window.location.href="/Home/Index";
					}
				},
				error:function(xhr){
					console.log(xhr)
					alert("error is occured");
				}

			})


		}

	</script>

</body>


</html>